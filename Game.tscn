[node name="BodyLabel" type="Label" parent="EmailPanel/MarginContainer/HBox/EmailSide/EmailBox/Margin/Content"]
layout_mode = 2
size_flags_vertical = 3
theme_override_font_sizes/font_size = 24
text = "Dear Student Representative,

We are pleased to inform you that the university will host the Spring Student Festival on campus. The aim is enhancing student engagement, enriching campus life, and fostering community interaction.

Please note that the university will provide financial support for this event, and it is strictly non-profit. If any profit is generated from the festival, it will be directly transferred to the school's scholarship fund.

Your responsibilities will include managing the project timeline, budget, and scope, ensuring that the festival is delivered successfully and safely.

Please review the Project Charter presented in the next screen, which outlines project objectives and success criteria. Once you accept, the preparation phase will officially begin.

Sincerely,
University Administration (Rectorate)"
autowrap_mode = 3

