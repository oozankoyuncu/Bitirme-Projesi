[node name="Text" type="Label" parent="TicketPricingPanel/InfoPopup/Margin/VBox/Scroll/Content/ObjectiveSection"]
layout_mode = 2
theme_override_colors/font_color = Color(0.8, 0.8, 0.8, 1)
theme_override_font_sizes/font_size = 18
text = "Choose a ticket price that maximizes total revenue, maintains strong attendance, and balances price with perceived event quality."
autowrap_mode = 3

[node name="ConsiderationsSection" type="VBoxContainer" parent="TicketPricingPanel/InfoPopup/Margin/VBox/Scroll/Content"]
layout_mode = 2

[node name="Label" type="Label" parent="TicketPricingPanel/InfoPopup/Margin/VBox/Scroll/Content/ConsiderationsSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "Key Strategic Considerations:"

[node name="Text" type="Label" parent="TicketPricingPanel/InfoPopup/Margin/VBox/Scroll/Content/ConsiderationsSection"]
layout_mode = 2
theme_override_colors/font_color = Color(0.8, 0.8, 0.8, 1)
theme_override_font_sizes/font_size = 18
text = "• Balance Price vs. Attendance: Higher attendance doesn't always mean higher revenue.
• Maximize Revenue: Focus on the combination of price and volume.
• Intelligence Trade-off: Consulting reveals precise data but reduces your initial budget.
• Long-term Impact: This is your main revenue source. Your ability to recover expenses depends on this decision.
• Calculation: Attendance = Base + (Base * Impact). *Base is hidden unless consulting is bought."
autowrap_mode = 3

