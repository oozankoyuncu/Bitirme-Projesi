layout_mode = 2
theme_override_colors/font_color = Color(0.7, 0.7, 0.7, 1)
theme_override_font_sizes/font_size = 22
text = "Calculated based on quantitative outcomes generated by strategic decisions. It combines the expected attendance from ticket pricing, the reach achieved through promotion strategies, the attractiveness of the entertainment lineup, and the engagement contribution of volunteer and club activities. These outputs are aggregated and normalized to form a comparable index. Decisions which increase attendance, visibility, and engagement directly improve the perceived quality of the event."
