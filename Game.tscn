[node name="Desc" type="Label" parent="CharterPanel/MarginContainer/TabContainer/Success/Margin/VBox/TabContent/KPI_List/SatisfactionKPI"]
layout_mode = 2
theme_override_colors/font_color = Color(0.7, 0.7, 0.7, 1)
theme_override_font_sizes/font_size = 22
text = "Determined through key experiential decisions using a threshold-based logic. Each major component—such as entertainment selection, volunteer and club structure, sound system choice, and decoration theme—is assessed based on whether it meets a predefined minimum requirement. Overall satisfaction increases as more of these requirements are fulfilled. This structure ensures that you must consistently meet baseline expectations across multiple areas rather than relying on a single strong decision."
autowrap_mode = 3

